<%- include('./partials/admin-header', { title: title, theme: theme, cacheBuster: cacheBuster, pageCSS: pageCSS, additionalCSS: additionalCSS }) %>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>

<div class="admin-layout">
  <%- include('./partials/admin-sidebar', { currentPage: 'analytics', admin: user }) %>

  <main class="admin-main">
    <%- include('./partials/admin-topbar', {
      breadcrumb: 'Analytics',
      breadcrumbSubtitle: 'Revenue, enrollments & student insights',
      showSearch: false
    }) %>

    <div class="admin-content">
      <div class="admin-dashboard admin-fade-in">
        <div class="admin-dashboard-header">
          <div class="dashboard-header-content">
            <div class="dashboard-header-left">
              <h1 class="admin-dashboard-title">
                <span class="title-icon">📈</span>
                Analytics
              </h1>
              <p class="admin-dashboard-subtitle">
                Filter by date range and courses/bundles. Paid checkout uses <strong>amounts students actually paid</strong> (promo discounts reduce totals). Students <strong>enrolled by admin</strong> without an order are counted as <strong>admin-placed revenue</strong> at today’s list prices.
              </p>
            </div>
          </div>
        </div>

        <section class="analytics-filters analytics-filters-toolbar">
          <div class="analytics-filters-head">
            <h2 class="analytics-section-title mb-0">Filters</h2>
            <p class="analytics-filters-hint mb-0">Date range applies to revenue (order date) and enrollments (enrolled date). Use search boxes to pick one or many bundles/courses.</p>
          </div>
          <div class="row g-3 align-items-end">
            <div class="col-lg-2 col-md-4">
              <label class="analytics-label" for="af-from">From</label>
              <input type="date" id="af-from" class="form-control analytics-input" value="<%= initialFrom %>">
            </div>
            <div class="col-lg-2 col-md-4">
              <label class="analytics-label" for="af-to">To</label>
              <input type="date" id="af-to" class="form-control analytics-input" value="<%= initialTo %>">
            </div>
            <div class="col-lg-4 col-md-6">
              <label class="analytics-label" for="af-bundles">Bundles <span class="text-muted fw-normal">(multi-select)</span></label>
              <select id="af-bundles" multiple autocomplete="off" placeholder="Search bundles…"></select>
            </div>
            <div class="col-lg-4 col-md-6">
              <label class="analytics-label" for="af-courses">Courses <span class="text-muted fw-normal">(multi-select)</span></label>
              <select id="af-courses" multiple autocomplete="off" placeholder="Search courses…"></select>
            </div>
            <div class="col-lg-12 col-md-4 d-flex flex-wrap gap-2 justify-content-lg-end analytics-filter-actions">
              <button type="button" id="af-apply" class="analytics-btn-primary analytics-btn-lg">
                <i class="fas fa-filter me-2"></i>Apply filter
              </button>
              <a
                href="#"
                id="af-xlsx"
                class="analytics-btn-outline analytics-btn-lg text-decoration-none d-inline-flex align-items-center"
                title="Multi-sheet Excel export: summary, test type, bundles, courses, weekly trend, demographics, bundle weeks (if one bundle selected)"
              >
                <i class="fas fa-file-excel me-2"></i>Dashboard · Excel
              </a>
              <a
                href="#"
                id="af-pdf"
                class="analytics-btn-outline analytics-btn-lg text-decoration-none d-inline-flex align-items-center"
                title="Executive PDF: KPIs, charts data highlights, optional bundle week detail"
              >
                <i class="fas fa-file-pdf me-2"></i>Dashboard · PDF
              </a>
            </div>
          </div>
        </section>

        <div
          id="analytics-dashboard-body"
          class="analytics-dashboard-body analytics-dashboard-body--loading"
          aria-busy="true"
          aria-describedby="analytics-loader-status"
        >
          <div
            id="analytics-page-loader"
            class="analytics-page-loader"
            role="status"
            aria-live="polite"
          >
            <div class="analytics-page-loader__card">
              <div class="analytics-page-loader__spinner" aria-hidden="true"></div>
              <p class="analytics-page-loader__title" id="analytics-loader-status">Loading analytics</p>
              <p class="analytics-page-loader__hint">Fetching revenue, enrollments, and charts. This can take up to a minute for large date ranges.</p>
            </div>
          </div>

        <section class="analytics-kpi-section" aria-label="Summary KPIs">
          <div class="analytics-kpi-grid" id="af-kpi">
            <article class="analytics-kpi-card">
              <div class="analytics-kpi-icon-wrap"><i class="fas fa-coins" aria-hidden="true"></i></div>
              <div class="analytics-kpi-text">
                <span class="analytics-kpi-label">Total revenue <span class="analytics-kpi-hint" id="kpi-total-rev-hint">(platform)</span></span>
                <span class="analytics-kpi-value" id="kpi-total-rev">—</span>
                <p class="analytics-kpi-subline d-none" id="kpi-scoped-rev-wrap"><span id="kpi-scoped-rev">—</span></p>
              </div>
            </article>
            <article class="analytics-kpi-card analytics-kpi-card-accent">
              <div class="analytics-kpi-icon-wrap"><i class="fas fa-graduation-cap" aria-hidden="true"></i></div>
              <div class="analytics-kpi-text">
                <span class="analytics-kpi-label">SAT <span class="analytics-kpi-hint">(by test type)</span></span>
                <span class="analytics-kpi-value" id="kpi-rev-sat">—</span>
                <p class="analytics-kpi-subline"><span id="kpi-stu-sat">—</span> students enrolled</p>
              </div>
            </article>
            <article class="analytics-kpi-card analytics-kpi-card-accent">
              <div class="analytics-kpi-icon-wrap"><i class="fas fa-clipboard-check" aria-hidden="true"></i></div>
              <div class="analytics-kpi-text">
                <span class="analytics-kpi-label">EST <span class="analytics-kpi-hint">(by test type)</span></span>
                <span class="analytics-kpi-value" id="kpi-rev-est">—</span>
                <p class="analytics-kpi-subline"><span id="kpi-stu-est">—</span> students enrolled</p>
              </div>
            </article>
            <article class="analytics-kpi-card">
              <div class="analytics-kpi-icon-wrap"><i class="fas fa-users" aria-hidden="true"></i></div>
              <div class="analytics-kpi-text">
                <span class="analytics-kpi-label">All students <span class="analytics-kpi-hint">(distinct, in range)</span></span>
                <span class="analytics-kpi-value" id="kpi-students">—</span>
                <p class="analytics-kpi-subline text-truncate" id="kpi-other-types" title=""></p>
              </div>
            </article>
          </div>
          <p class="analytics-muted small mt-3 mb-0" id="kpi-rev-footnote" aria-live="polite"></p>
        </section>

        <div class="analytics-overview-card mb-4">
          <h3 class="analytics-section-title mb-3">Revenue vs students <span class="analytics-kpi-hint">(paid checkout + admin-placed)</span></h3>
          <div class="analytics-chart-tall">
            <canvas id="chart-rev-vs-stu" height="280"></canvas>
          </div>
        </div>

        <div class="analytics-overview-card mb-4">
          <h3 class="analytics-section-title mb-1">Platform revenue by week</h3>
          <p class="analytics-muted mb-3" id="weekly-trend-desc">Paid checkout only, by calendar week (ISO). Admin-placed revenue is not tied to a payment date, so it appears in weekly bundle breakdown and totals, not here.</p>
          <div class="analytics-chart-tall">
            <canvas id="chart-weekly-trend" height="260"></canvas>
          </div>
        </div>

        <div class="analytics-chart-grid">
          <div class="analytics-chart-card">
            <h3>Revenue by test type</h3>
            <canvas id="chart-rev-testtype" height="200"></canvas>
          </div>
          <div class="analytics-chart-card">
            <h3>Students by bundle</h3>
            <canvas id="chart-stu-bundle" height="200"></canvas>
          </div>
          <div class="analytics-chart-card">
            <h3>Revenue by bundle (paid + admin-placed)</h3>
            <canvas id="chart-rev-bundle" height="200"></canvas>
          </div>
          <div class="analytics-chart-card">
            <h3>Revenue by course (paid + admin-placed)</h3>
            <canvas id="chart-rev-course" height="200"></canvas>
          </div>
        </div>

        <section class="analytics-compare-panel analytics-compare-pro">
          <div class="d-flex flex-wrap align-items-start justify-content-between gap-2 mb-2">
            <h3 class="analytics-section-title mb-0">Compare</h3>
            <div class="analytics-section-export btn-group" role="group" aria-label="Export comparison">
              <a href="#" id="cmp-xlsx" class="btn btn-sm btn-outline-secondary text-nowrap" title="Excel: comparison table + parameters sheet"
                ><i class="fas fa-file-excel me-1"></i>Excel</a
              >
              <a href="#" id="cmp-pdf" class="btn btn-sm btn-outline-secondary text-nowrap" title="PDF report for current comparison settings"
                ><i class="fas fa-file-pdf me-1"></i>PDF</a
              >
            </div>
          </div>
          <p class="analytics-muted mb-3">Courses: pick <strong>2+ courses</strong>. Bundles: pick <strong>2+ bundles</strong>. Weeks: one bundle + week numbers. Ranges: two date ranges. Factor <strong>Revenue + students</strong> shows both on one chart (two axes). Revenue includes paid checkout + course lines + <strong>admin-placed</strong> where applicable.</p>
          <div id="cmp-status" class="analytics-cmp-alert d-none" role="status"></div>
          <div class="row g-3 mb-3">
            <div class="col-md-2">
              <label class="analytics-label" for="cmp-mode">Mode</label>
              <select id="cmp-mode" class="form-select analytics-input">
                <option value="courses">Courses</option>
                <option value="bundles">Bundles</option>
                <option value="weeks">Weeks (same bundle)</option>
                <option value="ranges">Two date ranges</option>
              </select>
            </div>
            <div class="col-md-2">
              <label class="analytics-label" for="cmp-factor">Factor</label>
              <select id="cmp-factor" class="form-select analytics-input">
                <option value="revenue">Revenue</option>
                <option value="students">Students</option>
                <option value="both">Revenue + students</option>
              </select>
            </div>
            <div class="col-md-4" id="cmp-courses-wrap">
              <label class="analytics-label" for="cmp-courses">Compare courses</label>
              <select id="cmp-courses" multiple autocomplete="off" placeholder="Pick 2+ courses…"></select>
            </div>
            <div class="col-md-4 d-none" id="cmp-bundles-wrap">
              <label class="analytics-label" for="cmp-bundles">Compare bundles</label>
              <select id="cmp-bundles" multiple autocomplete="off" placeholder="Pick 2+ bundles…"></select>
            </div>
            <div class="col-md-4 d-none" id="cmp-weeks-wrap">
              <label class="analytics-label" for="cmp-week-bundle">Bundle</label>
              <select id="cmp-week-bundle" autocomplete="off" placeholder="Select bundle…"></select>
            </div>
            <div class="col-md-4 d-none" id="cmp-weeks-input-wrap">
              <label class="analytics-label" for="cmp-weeks">Week numbers</label>
              <input type="text" id="cmp-weeks" class="form-control analytics-input" placeholder="e.g. 1, 2, 4">
            </div>
            <div class="col-md-3 d-none" id="cmp-rng-b-wrap">
              <label class="analytics-label" for="cmp-from-b">Range B — from</label>
              <input type="date" id="cmp-from-b" class="form-control analytics-input">
            </div>
            <div class="col-md-3 d-none" id="cmp-rng-b2-wrap">
              <label class="analytics-label" for="cmp-to-b">Range B — to</label>
              <input type="date" id="cmp-to-b" class="form-control analytics-input">
            </div>
          </div>
          <button type="button" id="cmp-apply" class="analytics-btn-outline analytics-btn-lg">
            <i class="fas fa-chart-bar me-2"></i>Update comparison chart
          </button>
          <div class="mt-3 analytics-compare-chart-wrap">
            <canvas id="chart-compare"></canvas>
          </div>
        </section>

        <section class="analytics-compare-panel">
          <div class="d-flex flex-wrap align-items-start justify-content-between gap-2 mb-2">
            <h3 class="analytics-section-title mb-0">Weekly breakdown</h3>
            <div class="analytics-section-export btn-group" role="group" aria-label="Export weekly breakdown">
              <a href="#" id="wk-xlsx" class="btn btn-sm btn-outline-secondary text-nowrap" title="Excel: totals + per-week rows (uses bundle selected below)"
                ><i class="fas fa-file-excel me-1"></i>Excel</a
              >
              <a href="#" id="wk-pdf" class="btn btn-sm btn-outline-secondary text-nowrap" title="PDF for selected bundle"
                ><i class="fas fa-file-pdf me-1"></i>PDF</a
              >
            </div>
          </div>
          <p class="analytics-muted mb-3"><strong>Active (period)</strong> = distinct students with an <strong>active</strong> enrollment whose <strong>start date</strong> falls in the filter range (used with revenue). <strong>On course</strong> = same headcount as the course details page (any status, any enrollment date). Revenue = direct + bundle share + admin-placed. Admin-placed counts only learners without paid access to that course; <strong>in admin-placed</strong> is how many enrollments added that value.</p>
          <div class="row g-3 align-items-end mb-2">
            <div class="col-md-5 col-lg-4">
              <label class="analytics-label" for="wk-bundle">Bundle</label>
              <select id="wk-bundle" autocomplete="off" placeholder="Search bundle…"></select>
            </div>
            <div class="col-md-auto">
              <button type="button" id="wk-load" class="analytics-btn-primary analytics-btn-lg">
                <i class="fas fa-calendar-week me-2"></i>Load weeks
              </button>
            </div>
            <div class="col-lg-7 analytics-wk-totals">
              <div class="analytics-wk-total-line">
                <span>Total week revenue: <strong id="wk-total-rev">—</strong></span>
              </div>
              <div class="analytics-wk-subtotals text-muted small">
                <span>Direct (course lines): <strong id="wk-total-direct">—</strong></span>
                <span class="ms-3">Bundle allocation: <strong id="wk-total-alloc">—</strong></span>
                <span class="ms-3" title="Students enrolled by admin without checkout, valued at list price">Admin-placed: <strong id="wk-total-imputed">—</strong></span>
              </div>
            </div>
          </div>
          <div class="analytics-weekly-cards" id="wk-cards"></div>
          <canvas id="chart-weekly-stu" class="mt-3" height="120"></canvas>
        </section>

        <section class="analytics-demographics-section mb-4">
          <h3 class="analytics-section-title mb-1">Demographics</h3>
          <p class="analytics-muted mb-3" id="demo-scope-line"></p>
          <div class="analytics-chart-grid">
            <div class="analytics-chart-card">
              <h3>Grades</h3>
              <canvas id="chart-grade"></canvas>
            </div>
            <div class="analytics-chart-card">
              <h3>English teachers</h3>
              <canvas id="chart-teacher"></canvas>
            </div>
            <div class="analytics-chart-card">
              <h3>Schools</h3>
              <canvas id="chart-school"></canvas>
            </div>
            <div class="analytics-chart-card">
              <h3>Countries</h3>
              <canvas id="chart-country"></canvas>
            </div>
          </div>
        </section>

        </div>

        <section class="analytics-student-log">
          <div class="d-flex flex-wrap align-items-start justify-content-between gap-2 mb-2">
            <h3 class="analytics-section-title mb-0">Student log</h3>
            <div class="analytics-section-export btn-group" role="group" aria-label="Export search results">
              <a href="#" id="stu-xlsx" class="btn btn-sm btn-outline-secondary text-nowrap" title="Excel: uses the same search text as the box below (min 2 characters)"
                ><i class="fas fa-file-excel me-1"></i>Excel</a
              >
              <a href="#" id="stu-pdf" class="btn btn-sm btn-outline-secondary text-nowrap" title="PDF listing from current search"
                ><i class="fas fa-file-pdf me-1"></i>PDF</a
              >
            </div>
          </div>
          <p class="analytics-muted mb-3">Search by name or code; open a row for payments, enrollments, and progress. Exports use the <strong>current search text</strong> (not the open detail panel).</p>
          <div class="row g-3">
            <div class="col-lg-5">
              <label class="analytics-label" for="stu-q">Search</label>
              <div class="input-group">
                <span class="input-group-text analytics-input-group-text"><i class="fas fa-search"></i></span>
                <input type="search" id="stu-q" class="form-control analytics-input" placeholder="Name or student code (min 2 characters)">
              </div>
            </div>
            <div class="col-lg-7">
              <label class="analytics-label">Results</label>
              <div id="stu-results-wrap" class="analytics-table-wrap">
                <div id="stu-results-empty" class="analytics-table-empty text-muted small">Type to search…</div>
                <div id="stu-results" class="table-responsive d-none"></div>
              </div>
            </div>
          </div>
          <div id="stu-detail" class="analytics-student-detail d-none"></div>
        </section>
      </div>
    </div>
  </main>
</div>

<script>
(function () {
  const BUNDLES = <%- bundlesJson %>;
  const COURSES = <%- coursesJson %>;

  const chartColors = ['#b80101', '#2563eb', '#059669', '#d97706', '#7c3aed', '#db2777', '#0891b2', '#4b5563'];

  let charts = {};
  let tsBundles;
  let tsCourses;
  let tsCmpCourses;
  let tsCmpBundles;
  let tsCmpWeekBundle;
  let tsWkBundle;
  let analyticsLoadGen = 0;

  function buildAnalyticsSearchParams() {
    const { from, to, bundleIds, courseIds } = filterParams();
    const p = new URLSearchParams({ from, to });
    bundleIds.forEach((id) => p.append('bundleIds', id));
    courseIds.forEach((id) => p.append('courseIds', id));
    return p;
  }

  function setDashboardLoading(loading) {
    const shell = document.getElementById('analytics-dashboard-body');
    const statusEl = document.getElementById('analytics-loader-status');
    if (!shell) return;
    shell.classList.toggle('analytics-dashboard-body--loading', !!loading);
    shell.setAttribute('aria-busy', loading ? 'true' : 'false');
    if (statusEl) statusEl.textContent = loading ? 'Loading analytics…' : 'Analytics loaded';
  }

  function money(n) {
    if (n == null || isNaN(n)) return '—';
    return new Intl.NumberFormat(undefined, { maximumFractionDigits: 0 }).format(n) + ' EGP';
  }

  function escapeHtml(s) {
    if (s == null) return '';
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  function tsMultiValues(id) {
    const el = document.getElementById(id);
    if (!el || !el.tomselect) return [];
    const v = el.tomselect.getValue();
    return Array.isArray(v) ? v.filter(Boolean) : v ? [v] : [];
  }

  function tsSingleValue(id) {
    const el = document.getElementById(id);
    if (!el || !el.tomselect) return el ? el.value : '';
    const v = el.tomselect.getValue();
    if (Array.isArray(v)) return v[0] || '';
    return v || '';
  }

  const tsMultiDefaults = {
    plugins: ['remove_button'],
    maxOptions: null,
    hideSelected: true,
    create: false,
    render: {
      option: function (data, escape) {
        return '<div class="analytics-ts-option">' + escape(data.text) + '</div>';
      },
      item: function (data, escape) {
        return '<div class="analytics-ts-item">' + escape(data.text) + '</div>';
      },
    },
  };

  function filterParams() {
    const from = document.getElementById('af-from').value;
    const to = document.getElementById('af-to').value;
    return { from, to, bundleIds: tsMultiValues('af-bundles'), courseIds: tsMultiValues('af-courses') };
  }

  function exportHref(kind) {
    const { from, to, bundleIds, courseIds } = filterParams();
    const p = new URLSearchParams({ from, to });
    bundleIds.forEach((id) => p.append('bundleIds', id));
    courseIds.forEach((id) => p.append('courseIds', id));
    return kind === 'xlsx' ? '/admin/analytics/export.xlsx?' + p : '/admin/analytics/export.pdf?' + p;
  }

  function buildCompareExportQuery() {
    const { from, to, bundleIds, courseIds } = filterParams();
    const p = new URLSearchParams({ from, to });
    bundleIds.forEach((id) => p.append('bundleIds', id));
    courseIds.forEach((id) => p.append('courseIds', id));
    p.set('compare', document.getElementById('cmp-mode').value);
    p.set('factor', document.getElementById('cmp-factor').value);
    const mode = document.getElementById('cmp-mode').value;
    if (mode === 'courses') {
      tsMultiValues('cmp-courses').forEach((id) => p.append('compareCourseIds', id));
    } else if (mode === 'bundles') {
      tsMultiValues('cmp-bundles').forEach((id) => p.append('compareBundleIds', id));
    } else if (mode === 'weeks') {
      p.set('weekBundleId', tsSingleValue('cmp-week-bundle'));
      document
        .getElementById('cmp-weeks')
        .value.split(/[\s,]+/)
        .forEach((w) => {
          if (w) p.append('weeks', w);
        });
    } else if (mode === 'ranges') {
      p.set('fromA', document.getElementById('af-from').value);
      p.set('toA', document.getElementById('af-to').value);
      p.set('fromB', document.getElementById('cmp-from-b').value);
      p.set('toB', document.getElementById('cmp-to-b').value);
    }
    return p;
  }

  function buildWeeklyExportQuery() {
    const p = buildAnalyticsSearchParams();
    const bid = tsSingleValue('wk-bundle');
    if (!bid) return null;
    p.set('bundleId', bid);
    return p;
  }

  function buildStudentExportQuery() {
    const q = document.getElementById('stu-q').value.trim();
    if (q.length < 2) return null;
    return new URLSearchParams({ q });
  }

  function destroyChart(id) {
    if (charts[id]) {
      charts[id].destroy();
      delete charts[id];
    }
  }

  function doughnut(id, labels, data) {
    destroyChart(id);
    const ctx = document.getElementById(id);
    if (!ctx) return;

    const pairs = [];
    (labels || []).forEach((l, i) => {
      const v = Number(data[i]) || 0;
      if (v > 0) pairs.push({ label: l || 'Unknown', value: v });
    });
    const sum = pairs.reduce((a, p) => a + p.value, 0);

    if (!pairs.length || sum <= 0) {
      charts[id] = new Chart(ctx, {
        type: 'doughnut',
        data: {
          labels: ['No data in this range'],
          datasets: [
            {
              data: [1],
              backgroundColor: ['#e2e8f0'],
              borderWidth: 0,
            },
          ],
        },
        options: {
          plugins: {
            legend: { display: false },
            tooltip: { enabled: false },
          },
          maintainAspectRatio: true,
        },
      });
      return;
    }

    const pctLabels = pairs.map((p) => {
      const pct = Math.round((p.value / sum) * 100);
      return p.label + ' · ' + pct + '%';
    });

    charts[id] = new Chart(ctx, {
      type: 'doughnut',
      data: {
        labels: pctLabels,
        datasets: [
          {
            data: pairs.map((p) => p.value),
            backgroundColor: pairs.map((_, i) => chartColors[i % chartColors.length]),
            borderWidth: 2,
            borderColor: '#ffffff',
          },
        ],
      },
      options: {
        plugins: {
          legend: { position: 'bottom', labels: { boxWidth: 12, font: { size: 10 } } },
          tooltip: {
            callbacks: {
              label: function (c) {
                const raw = pairs[c.dataIndex];
                return raw ? raw.label + ': ' + raw.value + ' (' + Math.round((raw.value / sum) * 100) + '%)' : '';
              },
            },
          },
        },
        maintainAspectRatio: true,
      },
    });
  }

  function barChart(id, labels, values, yLabel) {
    destroyChart(id);
    const ctx = document.getElementById(id);
    if (!ctx) return;
    charts[id] = new Chart(ctx, {
      type: 'bar',
