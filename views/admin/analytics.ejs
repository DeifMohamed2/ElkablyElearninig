  async function loadCompare() {
    const statusEl = document.getElementById('cmp-status');
    statusEl.classList.add('d-none');
    statusEl.textContent = '';

    const { from, to, bundleIds, courseIds } = filterParams();
    const mode = document.getElementById('cmp-mode').value;
    const factor = document.getElementById('cmp-factor').value;
    const p = new URLSearchParams({ from, to, compare: mode, factor });
    bundleIds.forEach((id) => p.append('bundleIds', id));
    courseIds.forEach((id) => p.append('courseIds', id));
    if (mode === 'courses') {
      tsMultiValues('cmp-courses').forEach((id) => p.append('compareCourseIds', id));
    }
    if (mode === 'bundles') {
      tsMultiValues('cmp-bundles').forEach((id) => p.append('compareBundleIds', id));
    }
    if (mode === 'weeks') {
      p.set('weekBundleId', tsSingleValue('cmp-week-bundle'));
      document.getElementById('cmp-weeks').value.split(/[\s,]+/).forEach((w) => {
        if (w) p.append('weeks', w);
      });
    }
    if (mode === 'ranges') {
      p.set('fromA', document.getElementById('af-from').value);
      p.set('toA', document.getElementById('af-to').value);
      p.set('fromB', document.getElementById('cmp-from-b').value);
      p.set('toB', document.getElementById('cmp-to-b').value);
    }
    const res = await fetch('/admin/analytics/api/compare?' + p);
    const json = await res.json();
    if (!json.success) {
      statusEl.textContent = json.message || 'Comparison failed.';
      statusEl.classList.remove('d-none');
      destroyChart('chart-compare');
      return;
    }
    const d = json.data;
    let labels = d.labels || [];
    let values = d.values;

    if (factor === 'both') {
      const rev = d.valuesRevenue || [];
      const stu = d.valuesStudents || [];
      if (mode === 'ranges' && (!labels || !labels.length)) {
        labels = ['Range A', 'Range B'];
      }
      const baseLabels = labels || [];
      const len = Math.max(baseLabels.length, rev.length, stu.length);
      const revPad = Array.from({ length: len }, (_, i) => Number(rev[i]) || 0);
      const stuPad = Array.from({ length: len }, (_, i) => Number(stu[i]) || 0);
      const lbl = Array.from({ length: len }, (_, i) => baseLabels[i] || '—');
      const hasData =
        len > 0 && (revPad.some((v) => v > 0) || stuPad.some((v) => v > 0));
      if (!hasData) {
        statusEl.textContent =
          d.hint || 'Nothing to compare yet — check your selections or date range.';
        statusEl.classList.remove('d-none');
        destroyChart('chart-compare');
        return;
      }
      statusEl.classList.add('d-none');
      compareBarChartDual('chart-compare', lbl, revPad, stuPad);
      return;
    }

    if (mode === 'ranges') {
      labels = ['Range A', 'Range B'];
      values = factor === 'students' ? d.totalStudents : d.totalRevenue;
    }
    const vals = values || [];
    const hasData = vals.length > 0 && vals.some((v) => Number(v) > 0);
    if (!hasData) {
      statusEl.textContent =
        d.hint || 'Nothing to compare yet — check your selections or date range.';
      statusEl.classList.remove('d-none');
      destroyChart('chart-compare');
      return;
    }
    statusEl.classList.add('d-none');
    barChart('chart-compare', labels, vals, factor === 'students' ? 'Students' : 'EGP');
  }

