  function applySummary(json) {
    if (!json || !json.success) return false;
    const d = json.data;
    document.getElementById('kpi-total-rev').textContent = money(d.totalRevenue);
    const hintEl = document.getElementById('kpi-total-rev-hint');
    if (hintEl) {
      hintEl.textContent = d.revenueIsScoped ? '(filtered)' : '(platform)';
    }
    const foot = document.getElementById('kpi-rev-footnote');
    if (foot) {
      const parts = [];
      const adminPl = d.adminPlacedRevenue ?? d.imputedRevenue;
      if (d.revenueIsScoped) {
        parts.push(
          'Figures above are limited to the selected bundle(s) and/or course(s) in this date range. ' +
            'Total = paid checkout ' +
            money(d.cashRevenue) +
            ' + admin-placed ' +
            money(adminPl) +
            ' (admin enrollments without payment, at list price).',
        );
        if (d.platformTotalRevenue != null) {
          const pc = d.platformCashRevenue;
          const pa = d.platformAdminPlacedRevenue;
          parts.push(
            'Platform reference (unfiltered): ' +
              money(d.platformTotalRevenue) +
              ' total (' +
              money(pc) +
              ' paid checkout + ' +
              money(pa) +
              ' admin-placed).',
          );
        }
      } else if (d.cashRevenue != null && adminPl != null) {
        parts.push(
          'Platform total = paid checkout ' +
            money(d.cashRevenue) +
            ' + admin-placed ' +
            money(adminPl) +
            ' (students added by admin without payment, at list price).',
        );
      }
      parts.push(
        'SAT / EST / other amounts include paid lines for that test type in this view, plus admin-placed where applicable.',
      );
      parts.push(
        'SAT and EST student counts can overlap (one learner in both); “All students” is unique headcount.',
      );
      if (d.revenueTypesMatchTotal === false && d.testTypeRevenueSum != null) {
        parts.push(
          'Note: sum of test-type revenue (' +
            money(d.testTypeRevenueSum) +
            ') differs slightly from total — check rounding or data.',
        );
      }
      foot.textContent = parts.join(' ');
    }
    const wrap = document.getElementById('kpi-scoped-rev-wrap');
    const scopedLine = document.getElementById('kpi-scoped-rev');
    if (d.revenueIsScoped && d.platformTotalRevenue != null && scopedLine && wrap) {
      wrap.classList.remove('d-none');
      scopedLine.textContent =
        'Platform reference: ' +
        money(d.platformTotalRevenue) +
        ' · paid ' +
        money(d.platformCashRevenue) +
        ' + admin-placed ' +
        money(d.platformAdminPlacedRevenue);
    } else if (wrap) {
      wrap.classList.add('d-none');
    }
    document.getElementById('kpi-students').textContent = d.totalStudents;
    const tt = d.testTypeRevenue || {};
    document.getElementById('kpi-rev-sat').textContent = money(tt.SAT);
    document.getElementById('kpi-rev-est').textContent = money(tt.EST);
    const stt = d.studentsByTestType || {};
    document.getElementById('kpi-stu-sat').textContent =
      stt.SAT != null ? String(stt.SAT) : '—';
    document.getElementById('kpi-stu-est').textContent =
      stt.EST != null ? String(stt.EST) : '—';
    const otherRev = Object.entries(tt).filter(([k]) => k !== 'SAT' && k !== 'EST');
    const elOther = document.getElementById('kpi-other-types');
    if (otherRev.length) {
      elOther.textContent = otherRev.map(([k, v]) => k + ': ' + money(v)).join(' · ');
      elOther.setAttribute('title', elOther.textContent);
    } else {
      elOther.textContent = '';
      elOther.removeAttribute('title');
    }
    return true;
  }

