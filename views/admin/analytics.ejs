  let searchTimer;
  document.getElementById('stu-q').addEventListener('input', function () {
    clearTimeout(searchTimer);
    const q = this.value.trim();
    searchTimer = setTimeout(async () => {
      const box = document.getElementById('stu-results');
      const emptyEl = document.getElementById('stu-results-empty');
      box.innerHTML = '';
      if (q.length < 2) {
        box.classList.add('d-none');
        emptyEl.classList.remove('d-none');
        emptyEl.textContent = 'Type at least 2 characters…';
        return;
      }
      const res = await fetch('/admin/analytics/api/students/search?q=' + encodeURIComponent(q));
      const json = await res.json();
      if (!json.success) return;
      if (!json.data.length) {
        box.classList.add('d-none');
        emptyEl.classList.remove('d-none');
        emptyEl.textContent = 'No matches.';
        return;
      }
      emptyEl.classList.add('d-none');
      box.classList.remove('d-none');
      let html =
        '<table class="table table-hover table-sm align-middle analytics-stu-table mb-0"><thead><tr><th>Name</th><th>Code</th><th class="text-end">Details</th></tr></thead><tbody>';
      json.data.forEach((u) => {
        const id = u._id;
        html +=
          '<tr><td>' +
          escapeHtml(u.firstName + ' ' + u.lastName) +
          '</td><td><code class="analytics-code">' +
          escapeHtml(u.studentCode) +
          '</code></td><td class="text-end"><button type="button" class="btn btn-sm analytics-btn-view" data-stu-id="' +
          escapeHtml(String(id)) +
          '">View</button></td></tr>';
      });
      html += '</tbody></table>';
      box.innerHTML = html;
      box.querySelectorAll('[data-stu-id]').forEach((btn) => {
        btn.addEventListener('click', () => loadStudent(btn.getAttribute('data-stu-id')));
      });
    }, 320);
  });

