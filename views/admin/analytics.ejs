  async function refreshDashboardData() {
    const myGen = ++analyticsLoadGen;
    setDashboardLoading(true);
    const applyBtn = document.getElementById('af-apply');
    if (applyBtn) applyBtn.disabled = true;
    try {
      const p = buildAnalyticsSearchParams();
      const [sumRes, distRes] = await Promise.all([
        fetch('/admin/analytics/api/summary?' + p),
        fetch('/admin/analytics/api/distributions?' + p),
      ]);
      const sumJson = await sumRes.json();
      const distJson = await distRes.json();
      applySummary(sumJson);
      applyDistributionData(distJson, sumJson);
      await Promise.all([loadDemographics(), loadCompare(), loadWeeklyTrend()]);
    } catch (err) {
      console.error(err);
    } finally {
      if (myGen === analyticsLoadGen) {
        setDashboardLoading(false);
        if (applyBtn) applyBtn.disabled = false;
      }
    }
  }

