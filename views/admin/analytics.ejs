  async function loadStudent(id) {
    const { from, to } = filterParams();
    const p = new URLSearchParams({ from, to });
    const res = await fetch('/admin/analytics/api/students/' + id + '?' + p);
    const json = await res.json();
    const panel = document.getElementById('stu-detail');
    if (!json.success) {
      panel.classList.add('d-none');
      return;
    }
    const d = json.data;
    const pr = d.profile;
    const activeBadge = pr.isActive
      ? '<span class="analytics-stu-badge analytics-stu-badge--ok">Active</span>'
      : '<span class="analytics-stu-badge analytics-stu-badge--muted">Inactive</span>';

    let html = '<div class="analytics-stu-pro">';
    html += '<div class="analytics-stu-pro-head">';
    html += '<div>';
    html +=
      '<div class="analytics-stu-pro-name">' +
      escapeHtml(pr.firstName + ' ' + pr.lastName) +
      ' <span class="analytics-stu-code">#' +
      escapeHtml(String(pr.studentCode)) +
      '</span></div>';
    html +=
      '<div class="analytics-stu-pro-meta">' +
      escapeHtml(pr.studentEmail || '') +
      (pr.grade ? ' · ' + escapeHtml(pr.grade) : '') +
      (pr.studentCountryCode ? ' · ' + escapeHtml(pr.studentCountryCode) : '') +
      '</div>';
    html += '<div class="analytics-stu-pro-signed">Signed up ' + new Date(pr.createdAt).toLocaleString() + '</div>';
    html += '</div><div class="analytics-stu-pro-head-actions">' + activeBadge + '</div></div>';

    if (d.showPaymentExplainer) {
      html +=
        '<div class="analytics-stu-callout analytics-stu-callout--compact">' +
        '<strong>How to read orders:</strong> List = catalog list price before promo. Paid share = amount attributed to each course or bundle line (promos scale those lines so they match what applies to learning items on the order).</div>';
    }

    html += '<div class="analytics-stu-kpi-row">';
    html +=
      '<div class="analytics-stu-kpi"><div class="analytics-stu-kpi-label">Total charged</div><div class="analytics-stu-kpi-value">' +
      money(d.totalPaid) +
      '</div><div class="analytics-stu-kpi-hint">Courses & bundles only, in date range</div></div>';
    html +=
      '<div class="analytics-stu-kpi"><div class="analytics-stu-kpi-label">Orders</div><div class="analytics-stu-kpi-value">' +
      (d.orderCount != null ? d.orderCount : (d.ordersDetail || d.purchases || []).length) +
      '</div></div>';
    if (d.sumCatalogLineList != null && Math.abs(Number(d.sumCatalogLineList) - Number(d.totalPaid)) > 0.5) {
      html +=
        '<div class="analytics-stu-kpi"><div class="analytics-stu-kpi-label">Sum of list (courses/bundles)</div><div class="analytics-stu-kpi-value analytics-stu-kpi-value--muted">' +
        money(d.sumCatalogLineList) +
        '</div><div class="analytics-stu-kpi-hint">Sum of list prices for shown lines; before promo scaling</div></div>';
    }
    if (d.adminPlacedValueInPeriodTotal != null && Number(d.adminPlacedValueInPeriodTotal) > 0) {
      html +=
        '<div class="analytics-stu-kpi"><div class="analytics-stu-kpi-label">Period unpaid</div><div class="analytics-stu-kpi-value">' +
        money(d.adminPlacedValueInPeriodTotal) +
        '</div><div class="analytics-stu-kpi-hint">Enrollments that <strong>started</strong> in this date range, after paid share</div></div>';
    }
    html += '</div>';

    const orders = d.ordersDetail || [];
    if (orders.length) {
      html += '<h5 class="analytics-stu-sec-title">Paid checkout</h5>';
      orders.forEach((ord) => {
        html += '<div class="analytics-stu-order">';
        html +=
          '<div class="analytics-stu-order-bar"><span class="analytics-stu-order-num">' +
          escapeHtml(String(ord.orderNumber || '—')) +
          '</span>';
        html += '<span class="analytics-stu-order-date">' + new Date(ord.createdAt).toLocaleString() + '</span>';
        html += '<span class="analytics-stu-order-total">' + money(ord.chargedTotal) + '</span></div>';
        if (ord.discountAmount > 0 || ord.promoCodeUsed) {
          html +=
            '<div class="analytics-stu-order-promo small text-muted">Promo' +
            (ord.promoCodeUsed ? ': ' + escapeHtml(ord.promoCodeUsed) : '') +
            (ord.discountAmount > 0 ? ' · −' + new Intl.NumberFormat(undefined, { maximumFractionDigits: 0 }).format(ord.discountAmount) + ' EGP' : '') +
            '</div>';
        }
        html +=
          '<table class="table table-sm analytics-stu-lines mb-0"><thead><tr><th>Item</th><th class="text-end">List</th><th class="text-end">Paid share</th></tr></thead><tbody>';
        ord.lines.forEach((ln) => {
          html +=
            '<tr><td>' +
            escapeHtml(ln.title) +
            ' <span class="text-muted small">' +
            escapeHtml(stuLineTypeLabel(ln.itemType)) +
            '</span></td><td class="text-end">' +
            money(ln.listPrice) +
            '</td><td class="text-end fw-semibold">' +
            money(ln.netPaid) +
            '</td></tr>';
        });
        html +=
          '<tr class="analytics-stu-lines-total"><td colspan="2" class="text-end">Charged total</td><td class="text-end">' +
          money(ord.chargedTotal) +
          '</td></tr>';
        html += '</tbody></table></div>';
      });
    } else {
      html += '<p class="analytics-muted small mb-3">No completed paid orders in this date range.</p>';
    }

    const apLines = d.adminPlacedLinesInPeriod || [];
    if (apLines.length) {
      html += '<h5 class="analytics-stu-sec-title mt-4">Unpaid in this period</h5>';
      html +=
        '<p class="analytics-muted small mb-2">Enrollments that <strong>started</strong> in the date range with unpaid catalog value left after paid checkout is applied.</p>';
      html +=
        '<div class="table-responsive"><table class="table table-sm analytics-stu-lines mb-0"><thead><tr><th>Course</th><th class="text-end">Amount</th></tr></thead><tbody>';
      apLines.forEach((ln) => {
        html +=
          '<tr><td>' +
          escapeHtml(ln.title || '') +
          '</td><td class="text-end fw-semibold">' +
          money(ln.amount) +
          '</td></tr>';
      });
      html += '</tbody></table></div>';
    }

    const adminA = d.adminPlacedAccess || [];
    if (adminA.length) {
      html += '<h5 class="analytics-stu-sec-title mt-4">Staff-added access</h5>';
      html +=
        '<p class="analytics-muted small mb-2">ADMIN/BULK enrollments on this student’s profile.</p>';
      html +=
        '<div class="table-responsive"><table class="table table-sm analytics-stu-lines mb-0"><thead><tr><th>Type</th><th>Title</th><th>Order</th><th class="text-end">List value</th><th>Since</th></tr></thead><tbody>';
      adminA.forEach((a) => {
        html +=
          '<tr><td>' +
          escapeHtml(a.kind) +
          '</td><td>' +
          escapeHtml(a.title) +
          (a.bundleTitle ? '<div class="small text-muted">' + escapeHtml(a.bundleTitle) + '</div>' : '') +
          '</td><td><code class="analytics-code">' +
          escapeHtml(String(a.orderNumber)) +
          '</code></td><td class="text-end">' +
          money(a.listPrice) +
          '</td><td class="small text-nowrap">' +
          new Date(a.purchasedAt).toLocaleDateString() +
          '</td></tr>';
      });
      html += '</tbody></table></div>';
    }

    html += '<div class="analytics-stu-enroll">';
    html += '<h5 class="analytics-stu-sec-title mt-4 mb-2">Courses &amp; progress</h5>';
    html +=
      '<p class="analytics-stu-enroll-hint">Paid = completed orders in the date range (per-course lines count for that week only; whole-bundle checkouts are split across all courses in the bundle by list price). Unpaid = catalog value still treated as not covered after that paid amount.</p>';
    html +=
      '<div class="table-responsive"><table class="table table-hover table-sm align-middle analytics-stu-lines analytics-stu-enroll-table mb-0"><thead><tr><th>Course</th><th>Bundle</th><th class="text-center">Wk</th><th class="text-end">Paid</th><th class="text-end">Unpaid</th><th>Progress</th><th class="text-center">Status</th></tr></thead><tbody>';
    (d.enrollments || []).forEach((e) => {
      const pct = Math.min(100, Math.max(0, Number(e.progress) || 0));
      const paidCell =
        e.paidInPeriod != null && Number(e.paidInPeriod) > 0 ? money(e.paidInPeriod) : '—';
      const unpaidCell =
        e.adminPlacedListValue != null && Number(e.adminPlacedListValue) > 0
          ? money(e.adminPlacedListValue)
          : '—';
      html +=
        '<tr><td>' +
        escapeHtml(e.title || '—') +
        '</td><td class="small text-muted">' +
        escapeHtml(e.bundleTitle || '—') +
        '</td><td class="text-center">' +
        (e.weekNumber != null ? escapeHtml(String(e.weekNumber)) : '—') +
        '</td><td class="text-end small fw-semibold">' +
        paidCell +
        '</td><td class="text-end small">' +
        unpaidCell +
        '</td><td style="min-width:148px"><div class="analytics-stu-progress-wrap"><div class="progress analytics-stu-progress" style="height:8px"><div class="progress-bar bg-danger" role="progressbar" style="width:' +
        pct +
        '%"></div></div><span class="analytics-stu-progress-pct">' +
        pct +
        '%</span></div></td><td class="text-center small">' +
        escapeHtml(e.status || '—') +
        '</td></tr>';
    });
    html += '</tbody></table></div>';
    html += '</div>';

    html += '</div>';
    panel.innerHTML = html;
    panel.classList.remove('d-none');
  }

  function toggleCompareUI() {
    const mode = document.getElementById('cmp-mode').value;
    document.getElementById('cmp-courses-wrap').classList.toggle('d-none', mode !== 'courses');
    document.getElementById('cmp-bundles-wrap').classList.toggle('d-none', mode !== 'bundles');
    document.getElementById('cmp-weeks-wrap').classList.toggle('d-none', mode !== 'weeks');
    document.getElementById('cmp-weeks-input-wrap').classList.toggle('d-none', mode !== 'weeks');
    const rng = mode === 'ranges';
    document.getElementById('cmp-rng-b-wrap').classList.toggle('d-none', !rng);
    document.getElementById('cmp-rng-b2-wrap').classList.toggle('d-none', !rng);
  }

  document.getElementById('cmp-mode').addEventListener('change', toggleCompareUI);

  document.getElementById('af-apply').addEventListener('click', refreshDashboardData);

  document.getElementById('cmp-apply').addEventListener('click', loadCompare);
  document.getElementById('wk-load').addEventListener('click', loadWeekly);

  document.getElementById('af-xlsx').addEventListener('click', (e) => {
    e.preventDefault();
    window.location.href = exportHref('xlsx');
  });
  document.getElementById('af-pdf').addEventListener('click', (e) => {
    e.preventDefault();
    window.location.href = exportHref('pdf');
  });

  document.getElementById('cmp-xlsx').addEventListener('click', (e) => {
    e.preventDefault();
    window.location.href = '/admin/analytics/export/compare.xlsx?' + buildCompareExportQuery().toString();
  });
  document.getElementById('cmp-pdf').addEventListener('click', (e) => {
    e.preventDefault();
    window.location.href = '/admin/analytics/export/compare.pdf?' + buildCompareExportQuery().toString();
  });

  document.getElementById('wk-xlsx').addEventListener('click', (e) => {
    e.preventDefault();
    const p = buildWeeklyExportQuery();
    if (!p) {
      window.alert('Select a bundle in Weekly breakdown, then export.');
      return;
    }
    window.location.href = '/admin/analytics/export/weekly.xlsx?' + p.toString();
  });
  document.getElementById('wk-pdf').addEventListener('click', (e) => {
    e.preventDefault();
    const p = buildWeeklyExportQuery();
    if (!p) {
      window.alert('Select a bundle in Weekly breakdown, then export.');
      return;
    }
    window.location.href = '/admin/analytics/export/weekly.pdf?' + p.toString();
  });

  document.getElementById('stu-xlsx').addEventListener('click', (e) => {
    e.preventDefault();
    const p = buildStudentExportQuery();
    if (!p) {
      window.alert('Type at least 2 characters in Student log search (same as live search).');
      return;
    }
    window.location.href = '/admin/analytics/export/students.xlsx?' + p.toString();
  });
  document.getElementById('stu-pdf').addEventListener('click', (e) => {
    e.preventDefault();
    const p = buildStudentExportQuery();
    if (!p) {
      window.alert('Type at least 2 characters in Student log search (same as live search).');
      return;
    }
    window.location.href = '/admin/analytics/export/students.pdf?' + p.toString();
  });

  const bundleOptions = BUNDLES.map((b) => ({
    value: b.id,
    text: b.title + ' (' + b.testType + ')',
  }));
  const courseOptions = COURSES.map((c) => ({
    value: c.id,
    text: c.title + (c.bundleTitle ? ' — ' + c.bundleTitle : ''),
  }));
  const courseShortOptions = COURSES.map((c) => ({
    value: c.id,
    text: c.title + (c.bundleTitle ? ' · ' + c.bundleTitle : ''),
  }));

  tsBundles = new TomSelect('#af-bundles', {
    ...tsMultiDefaults,
    placeholder: 'Search bundles…',
    options: bundleOptions,
  });
  tsCourses = new TomSelect('#af-courses', {
    ...tsMultiDefaults,
    placeholder: 'Search courses…',
    options: courseOptions,
  });
  tsCmpCourses = new TomSelect('#cmp-courses', {
    ...tsMultiDefaults,
    placeholder: 'Select 2 or more courses…',
    options: courseShortOptions,
  });
  tsCmpBundles = new TomSelect('#cmp-bundles', {
    ...tsMultiDefaults,
    placeholder: 'Select 2 or more bundles…',
    options: bundleOptions,
  });
  tsCmpWeekBundle = new TomSelect('#cmp-week-bundle', {
    maxItems: 1,
    maxOptions: null,
    create: false,
    options: bundleOptions,
    placeholder: 'Choose bundle…',
  });
  tsWkBundle = new TomSelect('#wk-bundle', {
    maxItems: 1,
    maxOptions: null,
    create: false,
    options: bundleOptions,
    placeholder: 'Choose bundle for weekly view…',
  });

  toggleCompareUI();
  refreshDashboardData();
})();
</script>

<%- include('./partials/admin-footer') %>
